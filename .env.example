# Copy this file to .env.local (for local dev) and fill in real values.
# Never commit .env or .env.local — see .gitignore. This file is the
# only one of the three tracked in the repo, and must never contain a
# real secret.

# --- Database ---
# PostgreSQL, local instance for now (see docs/adr/0001-postgres-persistence.md).
# Hosted/production provider still TBD.
DATABASE_URL=postgres://user:password@localhost:5432/printing_site

# --- Stripe (tentative payment provider, to be confirmed — see the
# constitution's Sync Impact Report) ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Auth: Google SSO gates the admin order queue ---
# Implementation not yet chosen (e.g. Clerk vs. Auth.js — ADR owed).
# Placeholder names below assume a direct Google OAuth client; update
# once the provider is picked.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
