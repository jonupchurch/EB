# Copy this file to .env.local (for local dev) and fill in real values.
# Never commit .env or .env.local — see .gitignore. This file is the
# only one of the three tracked in the repo, and must never contain a
# real secret.

# --- Database ---
# PostgreSQL — local instance for dev, Neon for Production/Preview (see
# docs/adr/0001-postgres-persistence.md, docs/adr/0008-neon-for-hosted-postgres.md).
DATABASE_URL=postgres://user:password@localhost:5432/printing_site

# Gates POST /api/admin/migrate — an internal ops route that applies
# pending Drizzle migrations against the real runtime database
# connection. Exists because Neon's DATABASE_URL is a Marketplace
# "Sensitive" secret: unavailable at build time and unreadable via
# `vercel env pull`, so there's no way to run `drizzle-kit migrate`
# against Production/Preview from a local machine otherwise.
MIGRATE_SECRET=

# --- Vercel Blob (product images — see
# docs/adr/0009-vercel-blob-for-product-images.md). In Production/Preview
# this is set automatically by the Vercel Blob integration; for local
# dev, pull it from `vercel env pull` or paste it in from the dashboard. ---
BLOB_READ_WRITE_TOKEN=

# --- PayPal (MVP payment provider — see
# docs/adr/0005-paypal-for-mvp-payments.md; Stripe is a planned
# fast-follow, not MVP) ---
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
# "sandbox" or "live" — defaults to sandbox if unset. Set explicitly to
# "live" only once real production PayPal credentials are in place;
# never inferred from NODE_ENV, so a real launch requires a deliberate
# flip, not an accidental one.
PAYPAL_MODE=sandbox

# --- Auth: Auth.js (Google provider), gates the admin order queue —
# see docs/adr/0006-authjs-for-google-sso.md ---
AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated allow-list of the exactly-two Google accounts
# permitted into /admin — never hardcode these in source.
ADMIN_ALLOWED_EMAILS=

# --- TaxJar (sales tax calculation — see
# docs/adr/0012-taxjar-for-sales-tax.md) ---
TAXJAR_API_KEY=
# "sandbox" or "live" — defaults to sandbox if unset, mirroring
# PAYPAL_MODE above. A sandbox key is only valid against TaxJar's
# sandbox API URL — the default (production) URL rejects it as
# unauthorized. Set explicitly to "live" only once a real TaxJar key
# is in place.
TAXJAR_MODE=sandbox

# --- Shippo (calculated/carrier-rate shipping — see
# docs/adr/0013-shippo-for-carrier-shipping-rates.md) ---
SHIPPO_API_KEY=

# --- Ship-from / tax-nexus address (the business's own location) —
# used by both tax.ts (TaxJar's from_* fields) and shipping.ts
# (Shippo's address_from). SHOP_ORIGIN_STREET1 MUST be a real street
# address before any live shipping label or tax filing depends on it —
# a placeholder is fine for sandbox/dev testing only. ---
SHOP_ORIGIN_NAME=Erica Burns Things
SHOP_ORIGIN_STREET1=
SHOP_ORIGIN_CITY=Parma
SHOP_ORIGIN_STATE=OH
SHOP_ORIGIN_ZIP=44134
SHOP_ORIGIN_COUNTRY=US

# --- Resend (transactional confirmation email — see
# docs/adr/0015-resend-for-transactional-email.md) ---
RESEND_API_KEY=
